{
  "name": "decentralized-bug-bounty-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "copy /y .env.anvil .env.local && next dev",
    "dev:sepolia": "copy /y .env.sepolia .env.local && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:local": "cd ../contracts && forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast",
    "deploy:sepolia": "cd ../contracts && forge script script/Deploy.s.sol --rpc-url %RPC_SEPOLIA% --broadcast --verify"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@tanstack/react-query": "^5.0.0",
    "autoprefixer": "10.4.15",
    "ethers": "^6.0.0",
    "ipfs-http-client": "^60.0.1",
    "lucide-react": "^0.292.0",
    "next": "^14.0.0",
    "postcss": "8.4.29",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "3.3.3",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.3"
  }
}
